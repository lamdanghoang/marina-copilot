# ============================================================
# DeFi Copilot Frontend — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# Backend API URL
# Local: http://localhost:3001
# Production: Your AWS Lambda API Gateway URL (e.g. https://abc123.execute-api.us-east-1.amazonaws.com)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Sui network to connect to (testnet | mainnet | devnet)
NEXT_PUBLIC_SUI_NETWORK=testnet

# zkLogin (Google OAuth) — optional, enables passwordless login
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# Enoki (managed zkLogin salt + proof) — optional
NEXT_PUBLIC_ENOKI_API_KEY=
