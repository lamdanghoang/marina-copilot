# ============================================================
# DeFi Copilot Backend — Environment Variables
# Copy to .env and fill in values
# ============================================================

# Server
PORT=3001

# CORS — Frontend origin allowed to call this API
# Local: http://localhost:3000
# Production: Your Vercel deployment URL (e.g. https://defi-copilot.vercel.app)
CORS_ORIGIN=http://localhost:3000

# AWS Credentials (for Bedrock LLM access)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Bedrock — LLM Model
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514

# Sui Blockchain RPC
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# MemWal (Walrus Memory) — persistent memory storage
MEMWAL_API_KEY=
MEMWAL_DELEGATE_KEY=

# Cetus DEX Aggregator
CETUS_API_URL=
